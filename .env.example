# Copy this file to `.env` (or set these as real environment variables on
# the host) for production deploys. Local `runserver` works fine without
# any of these — settings.py falls back to dev-safe defaults.
#
# Generate a fresh SECRET_KEY with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-fresh-50-char-random-string
DJANGO_ALLOWED_HOSTS=yourname.pythonanywhere.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourname.pythonanywhere.com
